import java.util.ArrayList;
import java.util.Scanner;

public class Main {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        ArrayList<String> nomes = new ArrayList<>();
        ArrayList<Integer> matriculas = new ArrayList<>();
        ArrayList<String> tipos = new ArrayList<>();
        ArrayList<Double> extras = new ArrayList<>();
        ArrayList<Double> salariosFinais = new ArrayList<>();

        final double SALARIO_BASE = 2000.0;

        int opcao;

        do {

            System.out.println("\n===== SISTEMA DE FOLHA DE PAGAMENTO =====");
            System.out.println("1 - Cadastrar Funcionário Padrão");
            System.out.println("2 - Cadastrar Funcionário Comissionado");
            System.out.println("3 - Cadastrar Funcionário Produção");
            System.out.println("4 - Gerar Folha de Pagamento");
            System.out.println("0 - Sair");
            System.out.print("Escolha uma opção: ");

            opcao = sc.nextInt();
            sc.nextLine();

            switch (opcao) {

                case 1:

                    System.out.println("\n=== Funcionário Padrão ===");

                    System.out.print("Nome: ");
                    String nomePadrao = sc.nextLine();

                    System.out.print("Matrícula: ");
                    int matPadrao = sc.nextInt();

                    nomes.add(nomePadrao);
                    matriculas.add(matPadrao);
                    tipos.add("Padrão");
                    extras.add(0.0);
                    salariosFinais.add(SALARIO_BASE);

                    System.out.println("Funcionário cadastrado com sucesso!");
                    break;

                case 2:

                    System.out.println("\n=== Funcionário Comissionado ===");

                    System.out.print("Nome: ");
                    String nomeCom = sc.nextLine();

                    System.out.print("Matrícula: ");
                    int matCom = sc.nextInt();

                    System.out.print("Valor total de vendas: ");
                    double vendas = sc.nextDouble();

                    System.out.print("Percentual de comissão: ");
                    double percentual = sc.nextDouble();

                    double comissao = vendas * percentual / 100;
                    double salarioCom = SALARIO_BASE + comissao;

                    nomes.add(nomeCom);
                    matriculas.add(matCom);
                    tipos.add("Comissionado");
                    extras.add(comissao);
                    salariosFinais.add(salarioCom);

                    System.out.println("Funcionário cadastrado com sucesso!");
                    break;

                case 3:

                    System.out.println("\n=== Funcionário Produção ===");

                    System.out.print("Nome: ");
                    String nomeProd = sc.nextLine();

                    System.out.print("Matrícula: ");
                    int matProd = sc.nextInt();

                    System.out.print("Quantidade de peças produzidas: ");
                    int quantidade = sc.nextInt();

                    System.out.print("Valor por peça: ");
                    double valorPeca = sc.nextDouble();

                    double bonus = quantidade * valorPeca;
                    double salarioProd = SALARIO_BASE + bonus;

                    nomes.add(nomeProd);
                    matriculas.add(matProd);
                    tipos.add("Produção");
                    extras.add(bonus);
                    salariosFinais.add(salarioProd);

                    System.out.println("Funcionário cadastrado com sucesso!");
                    break;

                case 4:

                    System.out.println("\n===== FOLHA DE PAGAMENTO =====");

                    System.out.println("Total de colaboradores: " + nomes.size());

                    for (int i = 0; i < nomes.size(); i++) {

                        System.out.println("\n-----------------------");
                        System.out.println("Nome: " + nomes.get(i));
                        System.out.println("Matrícula: " + matriculas.get(i));
                        System.out.println("Tipo: " + tipos.get(i));
                        System.out.println("Salário Base: R$ " + SALARIO_BASE);
                        System.out.println("Extras: R$ " + extras.get(i));
                        System.out.println("Salário Final: R$ " + salariosFinais.get(i));
                    }

                    break;

                case 0:

                    System.out.println("Programa encerrado.");
                    break;

                default:

                    System.out.println("Opção inválida!");
            }

        } while (opcao != 0);

        sc.close();
    }
}
